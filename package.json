{
  "name": "piano360",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,client -c cyan,green \"npm run dev -w @piano360/api\" \"npm run dev -w @piano360/client\"",
    "build": "npm run build --workspaces",
    "build:api": "npm run build -w @piano360/api",
    "heroku-postbuild": "npm run build:api",
    "seed:courses": "npm run seed:courses -w @piano360/api",
    "backup:data": "tsx apps/api/src/scripts/backupDatabase.ts",
    "start": "node apps/api/dist/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "npm test --workspaces",
    "test:browser": "playwright test",
    "typecheck": "npm run typecheck --workspaces"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  }
}
